import { NextRequest, NextResponse } from "next/server";

export async function GET(request: NextRequest): Promise<NextResponse> {
  const { searchParams } = new URL(request.url);
  const vat = searchParams.get("vat") || "";
  const country = searchParams.get("country") || "IT";

  if (!vat) {
    return NextResponse.json({ isValid: false, error: "VAT is required" }, { status: 400 });
  }

  const cleanVat = vat.replace(/[\s-]/g, "").toUpperCase();
  const prefix = cleanVat.substring(0, 2);
  let number = cleanVat;
  let targetCountry = country;

  if (prefix === country || (country === "EL" && prefix === "GR")) {
    number = cleanVat.substring(2);
  } else if (/^[A-Z]{2}$/.test(prefix)) {
    targetCountry = prefix === "GR" ? "EL" : prefix;
    number = cleanVat.substring(2);
  }

  try {
    const url = `https://ec.europa.eu/taxation_customs/vies/rest-api/ms/${targetCountry}/vat/${number}`;
    const res = await fetch(url, { 
      method: "GET", 
      headers: { "Accept": "application/json" } 
    });
    
    if (!res.ok) {
      console.warn("VIES API returned status:", res.status);
      // In caso di servizio offline o non raggiungibile, restituiamo un flag temporaneo
      // per consentire un inserimento manuale di emergenza sul client
      return NextResponse.json({ 
        isValid: false, 
        isOffline: true,
        error: "VIES service temporarily offline" 
      });
    }
    
    const data = (await res.json()) as { isValid?: boolean; name?: string; address?: string };
    
    let coordinates = null;
    if (data.isValid === true && data.address) {
      try {
        const cleanAddress = data.address.replace(/\n/g, ", ").trim();
        const query = `${cleanAddress}, ${targetCountry}`;
        const geocodeUrl = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1`;
        
        const geoRes = await fetch(geocodeUrl, {
          method: "GET",
          headers: {
            "User-Agent": "KALEX-SSO-App/1.0 (contact: info@kalex.com)"
          }
        });
        
        if (geoRes.ok) {
          const geoData = await geoRes.json();
          if (Array.isArray(geoData) && geoData.length > 0) {
            const lat = parseFloat(geoData[0].lat);
            const lon = parseFloat(geoData[0].lon);
            
            let altitude = null;
            try {
              const elevRes = await fetch(`https://api.open-meteo.com/v1/elevation?latitude=${lat}&longitude=${lon}`);
              if (elevRes.ok) {
                const elevData = (await elevRes.json()) as { elevation?: number[] };
                if (elevData && Array.isArray(elevData.elevation) && elevData.elevation.length > 0) {
                  altitude = elevData.elevation[0];
                }
              }
            } catch (elevErr) {
              console.warn("Elevation fetch failed:", elevErr);
            }
            
            coordinates = {
              latitude: lat,
              longitude: lon,
              altitude: altitude
            };
          }
        }
      } catch (geoErr) {
        console.error("Geocoding service error:", geoErr);
      }
    }

    return NextResponse.json({
      isValid: data.isValid === true,
      name: data.name || "",
      address: data.address || "",
      coordinates
    });
  } catch (err) {
    console.error("VIES proxy server error:", err instanceof Error ? err.message : err);
    return NextResponse.json({ 
      isValid: false, 
      isOffline: true,
      error: "VIES connection failed" 
    });
  }
}
